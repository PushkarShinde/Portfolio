# ═══════════════════════════════════════════════════════════════════════
# Environment Variables — Pushkar Shinde Portfolio
# ═══════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control — only .env.example is tracked.
# Vite exposes variables prefixed with VITE_ to the client bundle.
# ═══════════════════════════════════════════════════════════════════════

# ── EmailJS Configuration ────────────────────────────────────────────
# Sign up at https://www.emailjs.com to get these values.
VITE_EMAILJS_SERVICE_ID=your_emailjs_service_id
VITE_EMAILJS_TEMPLATE_ID=your_emailjs_template_id
VITE_EMAILJS_PUBLIC_KEY=your_emailjs_public_key

# ── Contact Details ──────────────────────────────────────────────────
VITE_CONTACT_EMAIL=your_email@example.com
VITE_CONTACT_NAME=Your Name
