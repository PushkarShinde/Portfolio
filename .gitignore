# ═══════════════════════════════════════════════════════════════════════
# .gitignore — Pushkar Shinde Portfolio
# ═══════════════════════════════════════════════════════════════════════

# ── Dependencies ─────────────────────────────────────────────────────
node_modules/

# ── Build Output ─────────────────────────────────────────────────────
dist/
dist-ssr/
build/

# ── Environment Variables (SENSITIVE — never commit) ─────────────────
.env
.env.local
.env.development
.env.development.local
.env.production
.env.production.local
.env.staging
.env.test
.env.test.local
# NOTE: .env.example IS tracked — it contains placeholder values only

# ── Logs ─────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ── Editor & IDE ─────────────────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.sublime-project
*.sublime-workspace

# ── OS Files ─────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini

# ── Vite / Local Dev ────────────────────────────────────────────────
*.local
.vite/

# ── Testing & Coverage ──────────────────────────────────────────────
coverage/
*.lcov
.nyc_output/

# ── Miscellaneous ────────────────────────────────────────────────────
*.tgz
*.tsbuildinfo
.eslintcache
.cache/
*.pem
